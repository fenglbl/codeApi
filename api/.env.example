NODE_ENV=development
PORT=18080
MONGODB_URI=mongodb://127.0.0.1:27017/codeaip
JWT_SECRET=replace_me
APP_ENCRYPTION_KEY=replace_with_32_byte_key
UPSTREAM_TIMEOUT_MS=150000
JSON_BODY_LIMIT=12mb
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
S3_ENABLED=false
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=codeaip-chat
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/codeaip-chat
S3_FORCE_PATH_STYLE=true
CHAT_IMAGE_MAX_MB=8
CHAT_IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp
